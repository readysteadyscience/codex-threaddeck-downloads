{
  "schemaVersion": "ctd.plugin.preview.v1",
  "id": "codex-threaddeck",
  "name": "Codex ThreadDeck",
  "version": "0.2.1",
  "stability": "experimental",
  "status": "preview-skeleton",
  "defaultInstallPackage": "ctd-project-kit-v0.2.1.zip",
  "capabilities": [
    "default-skill-trigger-diagnostics",
    "detect-project-state",
    "intent-compiler-routing-envelope",
    "recommend-execution-mode",
    "auto-route-hook-preview",
    "runtime-doctor",
    "reviewed-hook-installer",
    "history-vault-preview",
    "plan-dispatch",
    "recommend-bootstrap"
  ],
  "boundaries": [
    "does-not-inject-thread-tools",
    "auto-route-hook-is-advisory-only",
    "dispatch-plan-is-advisory-only",
    "high-risk-actions-use-manual-taskcards-or-confirmation",
    "does-not-create-background-workers-without-user-visible-routing",
    "requires-available-codex-thread-tools-for-real-dispatch"
  ]
}
